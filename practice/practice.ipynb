    "# 1. Take a number as input and print whether it is even or odd.\n",
    "def num_type():\n",
    "    num= int(input(\"enter a number: \"))\n",
    "    if num%2==0:\n",
    "        print(\"number is even\")\n",
    "    else:\n",
    "        print(\"number is odd\")\n",
    "num_type()"
